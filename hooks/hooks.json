{
  "_comment": "Hooks for the project-builder plugin. ${CLAUDE_PLUGIN_ROOT} expands to this plugin's install directory at runtime, so the paths resolve regardless of which subdirectory Claude was launched from.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/flush.py\" --trigger session-end",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/flush.py\" --trigger pre-compact",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/inject-context.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
