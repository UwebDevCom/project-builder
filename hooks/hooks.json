{
  "_comment": "Copy these hook entries into your project's .claude/settings.json under the 'hooks' key. Adjust paths if your plugin location differs.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/plugins/project-builder/scripts/flush.py --trigger session-end",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/plugins/project-builder/scripts/flush.py --trigger pre-compact",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/plugins/project-builder/scripts/inject-context.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
